\begin{frame}{Four basic premises}
\begin{enumerate}
 \item Science first
 \item Multi-state models are crucial
 \item Both rates \emph{and} absolute risk are needed
 \item The perfect one number summary is a search for El Dorado
\end{enumerate}
\end{frame}

\begin{frame}[fragile]{Mulit-state models}
