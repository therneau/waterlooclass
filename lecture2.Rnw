\begin{frame}{Cox partial likelihood}
$$
  PL(\beta) = \prod_{i \in D} \frac{dN_i(t) e^{x_i \beta}}
             {\sum_j Y_j(t) e^{x_j\beta}}
$$

 \begin{itemize}
    \item lottery model
    \item efficient computation $O(n) + O(dp^2)$
    \item Appendix A.3 in the book, simple + computer
    \item Cook, formal
 \end{itemize}
\end{frame}

