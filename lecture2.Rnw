statefig(rbind(3,1), smat2)
@
\end{frame}

\begin{frame}{Multi-state models}
\begin{itemize}
 \item Arrows: rates, hazard ratios
 \item  Boxes: absolute risk
   \begin{enumerate}
     \item $p_k(t; x)$: probability in state $k$ at time $t$
     \item $E[N_k(t; x)]$: number of visits to state $k$, by time $t$
     \item $\mbox{sojourn}_k(t; x)$: total time in state $k$, up to time $t$
     \item $\mbox{sojourn}_k(t;x)/E[N_k(t;z)]$ : expected time per visit
     \item $P_{jk}(t; x)$: a matrix, probability will be in state $k$ at time 
       $t$, given in state $j$ at time $s$
   \end{enumerate}
  \end{itemize}
\end{frame}

\begin{frame}{Form 1: extension of KM and Cox}
 \begin{itemize}
   \item Model the \emph{transitions}
   \item Prob(subject $i$ transitions from $j$ to $k$ at time $t$)
   \item Crazy fact: $PLL = \sum_{jk} PLL_{jk}$
   \item PLL = standard Cox partial log likelihood
   \item survfit does both single state (KM) and multi-state (AJ)
   \item coxph does both single state and multi-state
   \item Absolute risk requires all the $\lambda_{jk}$ estimates
   \end{itemize}
\end{frame}

\begin{frame}{Form 2: interval censored multistate}
  \begin{itemize}
   \item Model the \emph{observed state}
   \item P(in observed state $k$ at time $t$)
   \item Fit all states at once
     \begin{itemize}
        \item for a trial value $\hat\beta$ of $\beta$
	\item compute $\hat p(t; x_i, \hat\beta)$, for each subject
	\item compare $\hat p$ to observed state(s), update $\hat\beta$
      \end{itemize}
   \item Allows for much more general observations
      \begin{itemize}
         \item observed state
	 \item subset of states
	 \item biomarker of state (HMM)
      \end{itemize}
   \end{itemize}
\end{frame}

\begin{frame}{Questions}
  \begin{itemize}
    \item Cost/benefit of IC fits
    \item Time-dependent covariates and absolute risk
    \item External validation
  \end{itemize}
\end{frame}

